# ---------------------------------------------------------------------------
# sTablo — environment variables
# ---------------------------------------------------------------------------

# Vercel Postgres (Neon). On Vercel: Storage -> Create Database -> Postgres,
# then "Connect Project". Vercel injects POSTGRES_URL automatically.
# For local dev, copy the "POSTGRES_URL" value here (use the pooled URL).
POSTGRES_URL="postgres://user:password@host/db?sslmode=require"

# Auth.js — generate with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET="change-me-with-a-long-random-string"

# Optional: the first user that registers with this email becomes admin.
# Leave empty to instead promote via the seed script.
ADMIN_EMAIL=""
