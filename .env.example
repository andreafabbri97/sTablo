# ---------------------------------------------------------------------------
# sTablo — environment variables
# ---------------------------------------------------------------------------

# Vercel Postgres (Neon). On Vercel: Storage -> Create Database -> Postgres,
# then "Connect Project". Vercel injects POSTGRES_URL automatically.
# For local dev, copy the "POSTGRES_URL" value here (use the pooled URL).
POSTGRES_URL="postgres://user:password@host/db?sslmode=require"

# Auth.js — generate with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET="change-me-with-a-long-random-string"

# Optional: the first user that registers with this email becomes admin.
# Leave empty to instead promote via the seed script.
ADMIN_EMAIL=""

# ---------------------------------------------------------------------------
# Web Push (notifiche). Genera una coppia di chiavi VAPID con:
#   node -e "console.log(require('web-push').generateVAPIDKeys())"
# La PUBLIC va sia su NEXT_PUBLIC_VAPID_PUBLIC_KEY (inlined nel client al BUILD)
# sia letta dal server; la PRIVATE resta segreta lato server. Senza queste, le
# notifiche restano disattivate (no-op silenzioso).
# IMPORTANT: NEXT_PUBLIC_* viene incluso a build-time → dopo averle impostate su
# Vercel serve un nuovo deploy perché abbiano effetto.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
# Opzionale: contatto del mittente (default: mailto:notifiche@s-tablo.vercel.app)
VAPID_SUBJECT=""
